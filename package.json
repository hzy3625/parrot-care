{
  "name": "parrot-care-monorepo",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "install:web": "npm --prefix apps/web ci",
    "dev": "npm --prefix apps/web run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "check": "npm run check:structure && npm run check:web",
    "check:structure": "python3 scripts/verification/check_structure.py",
    "check:web": "npm --prefix apps/web run check",
    "test:api": "cd apps/api && ../../.venv/bin/python -m pytest tests -q"
  }
}
